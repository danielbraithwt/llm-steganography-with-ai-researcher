# Slack settings (bidirectional — agent posts status, you post directives)
SLACK_BOT_TOKEN=""                   # Bot token (xoxb-...) with channels:history + chat:write
SLACK_CHANNEL_ID=""                  # Channel ID for #research-agent (e.g. C07ABC123)
SLACK_WEBHOOK_URL=""                 # Incoming webhook URL (fallback if no bot token)

# Email settings
NOTIFICATION_EMAIL=""                # Email for digests (leave empty to skip)
EMAIL_DIGEST_EVERY=5                 # Send email digest every N cycles

# Compute budget
MAX_EXPERIMENT_MINUTES=30            # Max wall-clock per experiment
MAX_TOTAL_HOURS=48                   # Total compute budget
SLEEP_BETWEEN_CYCLES=30              # Seconds between cycles

# Agent settings
DRY_RUN=false                        # If true, propose but don't execute
LITERATURE_SCAN_EVERY=10             # Do a literature scan instead of experiment every N cycles

# Model settings (for experiments, not for the agent)
PRIMARY_MODEL="Qwen3-4B-Base"
REPLICATION_MODEL="Llama-3.1-8B-Base"
BENCHMARK="GSM8K"
NUM_SHOTS=8
